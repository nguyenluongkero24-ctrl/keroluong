        viewModelScope.launch {
            val override = com.example.data.model.MonthlyOverride(monthStr = monthStr, overriddenAttendanceBonus = amount)
            repository.saveMonthlyOverride(override)

            // Sync override to Firebase
            val user = auth?.currentUser
            val db = firestore
            if (user != null && db != null) {
                val overrideMap = hashMapOf(
                    "overriddenAttendanceBonus" to amount,
                    "updatedAt" to System.currentTimeMillis()
                )
                db.collection("users")
                    .document(user.uid)
                    .collection("overrides")
                    .document(monthStr)
                    .set(overrideMap, SetOptions.merge())
            }
        }
    }



    // Helper metadata for selected month
    fun getCalendarGridData(): List<CalendarDay> {
        val currentCal = _calendarDate.value.clone() as Calendar
        currentCal.set(Calendar.DAY_OF_MONTH, 1)

        val dayOfWeekOfFirst = currentCal.get(Calendar.DAY_OF_WEEK) // 1 = Sunday, 2 = Monday, ...
        val daysInMonth = currentCal.getActualMaximum(Calendar.DAY_OF_MONTH)

        // Convert dayOfWeek to 0-indexed Monday to Sunday:
        // Java Calendar: Sun=1, Mon=2, Tue=3, Wed=4, Thu=5, Fri=6, Sat=7
        // Monday-first sorting: Mon=0, Tue=1, Wed=2, Thu=3, Fri=4, Sat=5, Sun=6
        val prefixEmptyCells = when (dayOfWeekOfFirst) {
            Calendar.MONDAY -> 0
            Calendar.TUESDAY -> 1
            Calendar.WEDNESDAY -> 2
            Calendar.THURSDAY -> 3
            Calendar.FRIDAY -> 4
            Calendar.SATURDAY -> 5
            Calendar.SUNDAY -> 6
            else -> 0
        }

        val list = mutableListOf<CalendarDay>()
        // Add padding days from the previous month for proper alignments
        for (i in 0 until prefixEmptyCells) {
            list.add(CalendarDay(dateString = "", dayNumber = 0, isCurrentMonth = false))
        }

        // Add actual days of the month
        val baseYear = currentCal.get(Calendar.YEAR)
        val baseMonth = currentCal.get(Calendar.MONTH) // 0-indexed
        for (day in 1..daysInMonth) {
            val dateCal = Calendar.getInstance()
            dateCal.set(baseYear, baseMonth, day)
            val dateStr = dateFormat.format(dateCal.time)
            list.add(CalendarDay(dateString = dateStr, dayNumber = day, isCurrentMonth = true))
        }

        return list
    }

    // Factory Class for robust creation
    class Factory(private val application: Application) : ViewModelProvider.Factory {
        override fun <T : ViewModel> create(modelClass: Class<T>): T {
            if (modelClass.isAssignableFrom(SalaryViewModel::class.java)) {
                @Suppress("UNCHECKED_CAST")
                val db = AppDatabase.getDatabase(application)
                val repository = SalaryRepository(db.salaryDao())
                return SalaryViewModel(application, repository) as T
            }
            throw IllegalArgumentException("Unknown ViewModel class")
        }
    }
}

data class CalendarDay(
    val dateString: String,
    val dayNumber: Int,
    val isCurrentMonth: Boolean
)
