            repository.getWorkEntriesForMonth(month)
        }
        .stateIn(
            scope = viewModelScope,
            started = SharingStarted.WhileSubscribed(5000),
            initialValue = emptyList()
        )

    // Flow of all Overridden Monthly Attendance Bonuses
    val allMonthlyOverrides: StateFlow<List<com.example.data.model.MonthlyOverride>> = repository.allMonthlyOverridesFlow
        .stateIn(
            scope = viewModelScope,
            started = SharingStarted.WhileSubscribed(5000),
            initialValue = emptyList()
        )

    // Selected day's editing work entry state
    var editWorkContent by mutableStateOf("")
    var editStartTime by mutableStateOf("")
    var editEndTime by mutableStateOf("")
    var editOvertimeHours by mutableStateOf("")
    var editIsOffDay by mutableStateOf(false)

    // Settings editing states
    var editBaseSalary by mutableStateOf("210000") // 21 man
    var editAttendanceBonus by mutableStateOf("20000") // 2 man
    var editTotalWorkDaysYear by mutableStateOf("250") // 250 days standard
    var editStandardHoursDay by mutableStateOf("7.75") // 7.75 hours standard

    // Show setting save feedback
    var settingsSavedStatus by mutableStateOf(false)

    // --- Firebase Auth & Firestore Synchronization States ---
    val auth: FirebaseAuth? by lazy {
        try {
            FirebaseAuth.getInstance()
        } catch (e: Exception) {
            Log.e("Firebase", "Failed to get FirebaseAuth instance: ${e.message}")
            null
        }
    }

    val firestore: FirebaseFirestore? by lazy {
        try {
            FirebaseFirestore.getInstance()
        } catch (e: Exception) {
            Log.e("Firebase", "Failed to get FirebaseFirestore instance: ${e.message}")
            null
        }
    }

    private val _currentUser = MutableStateFlow<FirebaseUser?>(null)
    val currentUser: StateFlow<FirebaseUser?> = _currentUser.asStateFlow()

    var authEmail by mutableStateOf("")
    var authPassword by mutableStateOf("")
    var isRegistering by mutableStateOf(false)
    var authErrorMessage by mutableStateOf<String?>(null)
    var isAuthLoading by mutableStateOf(false)
    var isSyncing by mutableStateOf(false)
    var lastSyncTime by mutableStateOf<String?>(null)

    init {
        try {
            val a = auth
            if (a != null) {
                _currentUser.value = a.currentUser
                a.addAuthStateListener { firebaseAuth ->
                    val prevUser = _currentUser.value
                    val newUser = firebaseAuth.currentUser
                    _currentUser.value = newUser
                    
                    // Auto sync-down when client connects or transitions to logged-in user
                    if (newUser != null && prevUser?.uid != newUser.uid) {
                        syncData()
                    }
                }
            }
        } catch (e: Exception) {
            Log.e("Firebase", "Error in Auth State Listener initialization: ${e.message}")
        }

        // Initialize settings fields when settings are loaded from DB
        viewModelScope.launch {
            val settings = repository.getSettingsDirect()
            editBaseSalary = if (settings.baseSalary == 0.0) "" else settings.baseSalary.toInt().toString()
            editAttendanceBonus = if (settings.attendanceBonus == 0.0) "" else settings.attendanceBonus.toInt().toString()
            editTotalWorkDaysYear = if (settings.totalWorkDaysYear == 0.0) "250" else if (settings.totalWorkDaysYear % 1.0 == 0.0) settings.totalWorkDaysYear.toInt().toString() else settings.totalWorkDaysYear.toString()
            editStandardHoursDay = if (settings.standardHoursDay == 0.0) "7.75" else settings.standardHoursDay.toString()
            
            // Also load today's entry
            selectDate(_selectedDateStr.value)
        }
    }

    // --- Firebase Authentication Methods ---
    fun loginWithEmail(onSuccess: () -> Unit = {}, onFailure: (String) -> Unit = {}) {
        val a = auth ?: run {
            authErrorMessage = "Firebase không khả dụng."
            onFailure(authErrorMessage!!)
            return
        }
        if (authEmail.isBlank() || authPassword.isBlank()) {
            authErrorMessage = "Vui lòng nhập đầy đủ email và mật khẩu."
            return
        }
        isAuthLoading = true
        authErrorMessage = null
        a.signInWithEmailAndPassword(authEmail.trim(), authPassword)
            .addOnCompleteListener { task ->
                isAuthLoading = false
                if (task.isSuccessful) {
                    authErrorMessage = null
                    onSuccess()
                } else {
                    authErrorMessage = task.exception?.localizedMessage ?: "Đăng nhập thất bại"
                    onFailure(authErrorMessage!!)
                }
            }
    }

