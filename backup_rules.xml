        .stateIn(
            scope = viewModelScope,
            started = SharingStarted.WhileSubscribed(5000),
            initialValue = SalarySettings()
        )

    // Work entries for the selected month
    val currentMonthEntries: StateFlow<List<WorkEntry>> = calendarMonthStr
