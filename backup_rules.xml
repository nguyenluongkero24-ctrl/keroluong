        }
        _currentUser.value = null
        lastSyncTime = null
    }

    // --- Firebase real-time sync / saveAttendance implementation ---
    fun saveAttendance(entry: WorkEntry) {
        val user = auth?.currentUser ?: return
        val db = firestore ?: return
        val userId = user.uid
        val dateId = entry.dateString

        val recordMap = hashMapOf(
            "dateString" to entry.dateString,
            "workContent" to entry.workContent,
            "startTime" to entry.startTime,
            "endTime" to entry.endTime,
            "overtimeHours" to entry.overtimeHours,
            "isOffDay" to entry.isOffDay,
            "updatedAt" to System.currentTimeMillis()
        )

        // Store standard layout: users/{userId}/records/{date_id}
        db.collection("users")
            .document(userId)
            .collection("records")
            .document(dateId)
            .set(recordMap, SetOptions.merge())
            .addOnSuccessListener {
                Log.d("FirebaseSync", "Synced WorkEntry for: $dateId to cloud")
            }
            .addOnFailureListener { e ->
                Log.e("FirebaseSync", "Failed sync for: $dateId. Error: ${e.message}")
            }
    }

    // Sync all Cloud Data to local Room database (Bi-directional fallback)
    fun syncData(onComplete: (Boolean) -> Unit = {}) {
        val user = auth?.currentUser ?: run {
            onComplete(false)
            return
        }
        val db = firestore ?: run {
            onComplete(false)
            return
        }
        val userId = user.uid
        isSyncing = true

        // 1. Pull work records from users/{userId}/records/
        db.collection("users")
            .document(userId)
            .collection("records")
            .get()
            .addOnSuccessListener { querySnapshot ->
                viewModelScope.launch {
                    val cloudEntries = querySnapshot.documents.mapNotNull { doc ->
                        val dateString = doc.id
                        val workContent = doc.getString("workContent") ?: ""
                        val startTime = doc.getString("startTime") ?: ""
                        val endTime = doc.getString("endTime") ?: ""
                        val overtimeHours = doc.getDouble("overtimeHours") ?: 0.0
                        val isOffDay = doc.getBoolean("isOffDay") ?: false
                        WorkEntry(
                            dateString = dateString,
                            workContent = workContent,
                            startTime = startTime,
                            endTime = endTime,
                            overtimeHours = overtimeHours,
                            isOffDay = isOffDay
                        )
                    }

                    // 2. Pull settings from users/{userId}/settings/salary_settings
                    db.collection("users")
                        .document(userId)
                        .collection("settings")
                        .document("salary_settings")
                        .get()
                        .addOnSuccessListener { settingsDoc ->
                            viewModelScope.launch {
                                val cloudSettings = if (settingsDoc.exists()) {
                                    SalarySettings(
                                        id = 1,
                                        baseSalary = settingsDoc.getDouble("baseSalary") ?: 210000.0,
                                        attendanceBonus = settingsDoc.getDouble("attendanceBonus") ?: 20000.0,
                                        totalWorkDaysYear = settingsDoc.getDouble("totalWorkDaysYear") ?: 250.0,
                                        standardHoursDay = settingsDoc.getDouble("standardHoursDay") ?: 7.75
                                    )
                                } else {
                                    null
                                }

                                // 3. Pull monthly overrides from users/{userId}/overrides
                                db.collection("users")
                                    .document(userId)
                                    .collection("overrides")
                                    .get()
                                    .addOnSuccessListener { overridesSnapshot ->
                                        val cloudOverrides = overridesSnapshot.documents.mapNotNull { overrideDoc ->
                                            val monthStr = overrideDoc.id
                                            val amount = overrideDoc.getDouble("overriddenAttendanceBonus") ?: return@mapNotNull null
                                            com.example.data.model.MonthlyOverride(monthStr, amount)
                                        }

                                        viewModelScope.launch {
                                            // Perform complete atomic database restoration locally
                                            repository.restoreDatabase(
                                                settings = cloudSettings,
                                                workEntries = cloudEntries,
                                                monthlyOverrides = cloudOverrides
                                            )

                                            // Re-initialize ViewModel editing fields with newly pulled properties
                                            val currentSettings = repository.getSettingsDirect()
                                            editBaseSalary = if (currentSettings.baseSalary == 0.0) "" else currentSettings.baseSalary.toInt().toString()
                                            editAttendanceBonus = if (currentSettings.attendanceBonus == 0.0) "" else currentSettings.attendanceBonus.toInt().toString()
                                            editTotalWorkDaysYear = if (currentSettings.totalWorkDaysYear % 1.0 == 0.0) currentSettings.totalWorkDaysYear.toInt().toString() else currentSettings.totalWorkDaysYear.toString()
                                            editStandardHoursDay = currentSettings.standardHoursDay.toString()

                                            selectDate(_selectedDateStr.value)

                                            val nowStr = SimpleDateFormat("dd/MM/yyyy HH:mm", Locale.getDefault()).format(Date())
                                            lastSyncTime = "Đồng bộ: $nowStr"
                                            isSyncing = false
                                            onComplete(true)
                                        }
                                    }
                                    .addOnFailureListener {
                                        isSyncing = false
                                        onComplete(false)
                                    }
                            }
                        }
                        .addOnFailureListener {
                            isSyncing = false
                            onComplete(false)
                        }
                }
            }
            .addOnFailureListener {
                isSyncing = false
                onComplete(false)
            }
    }

    // Navigation and Calendar
    fun previousMonth() {
        val currentCal = _calendarDate.value.clone() as Calendar
        currentCal.add(Calendar.MONTH, -1)
        _calendarDate.value = currentCal
    }

    fun nextMonth() {
        val currentCal = _calendarDate.value.clone() as Calendar
        currentCal.add(Calendar.MONTH, 1)
        _calendarDate.value = currentCal
    }

    // Set active month and year directly
    fun setDate(date: Date) {
        val cal = Calendar.getInstance()
        cal.time = date
        _calendarDate.value = cal
    }

    // Select date for editing
    fun selectDate(dateStr: String) {
        _selectedDateStr.value = dateStr
        viewModelScope.launch {
            val entry = repository.getWorkEntryByDate(dateStr)
            editWorkContent = entry.workContent
            editStartTime = entry.startTime
            editEndTime = entry.endTime
            editOvertimeHours = if (entry.overtimeHours == 0.0) "" else if (entry.overtimeHours % 1.0 == 0.0) entry.overtimeHours.toInt().toString() else entry.overtimeHours.toString()
            editIsOffDay = entry.isOffDay
        }
    }

    // Auto-save Work Entry to Room & Real-time Cloud Sync
    fun saveWorkEntry() {
        viewModelScope.launch {
            val otHours = editOvertimeHours.toDoubleOrNull() ?: 0.0
            val entry = WorkEntry(
                dateString = _selectedDateStr.value,
                workContent = editWorkContent,
                startTime = editStartTime,
                endTime = editEndTime,
                overtimeHours = otHours,
                isOffDay = editIsOffDay
            )
            repository.saveWorkEntry(entry)
            
            // Sync to Firebase in real-time
            if (auth?.currentUser != null) {
                saveAttendance(entry)
            }
        }
    }

