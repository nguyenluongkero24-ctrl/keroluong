    }

    fun updateIsOffDay(value: Boolean) {
        editIsOffDay = value
        saveWorkEntry()
    }

    // Delete active day work entry
    fun clearOrDeleteWorkEntry() {
        viewModelScope.launch {
            val dateStr = _selectedDateStr.value
            repository.deleteWorkEntryByDate(dateStr)
            editWorkContent = ""
            editStartTime = ""
            editEndTime = ""
            editOvertimeHours = ""
            editIsOffDay = false
            
            // Sync deletion to cloud
            val user = auth?.currentUser
            val db = firestore
            if (user != null && db != null) {
                db.collection("users")
                    .document(user.uid)
                    .collection("records")
                    .document(dateStr)
                    .delete()
                    .addOnSuccessListener {
                        Log.d("FirebaseSync", "Deleted record on Cloud for date: $dateStr")
                    }
            }
        }
    }

    // Save configurations automatically to Room
    fun saveSettings() {
        viewModelScope.launch {
            val baseSal = editBaseSalary.toDoubleOrNull() ?: 0.0
            val attBonus = editAttendanceBonus.toDoubleOrNull() ?: 0.0
            val daysYear = editTotalWorkDaysYear.toDoubleOrNull() ?: 250.0
            val hoursDay = editStandardHoursDay.toDoubleOrNull() ?: 7.75

            val config = SalarySettings(
                id = 1,
                baseSalary = baseSal,
                attendanceBonus = attBonus,
                totalWorkDaysYear = daysYear,
                standardHoursDay = hoursDay
            )
            repository.saveSettings(config)
            settingsSavedStatus = true

            // Sync settings to Firebase
            val user = auth?.currentUser
            val db = firestore
            if (user != null && db != null) {
                val settingsMap = hashMapOf(
                    "baseSalary" to baseSal,
                    "attendanceBonus" to attBonus,
                    "totalWorkDaysYear" to daysYear,
                    "standardHoursDay" to hoursDay,
                    "updatedAt" to System.currentTimeMillis()
                )
                db.collection("users")
                    .document(user.uid)
                    .collection("settings")
                    .document("salary_settings")
                    .set(settingsMap, SetOptions.merge())
            }
        }
    }

